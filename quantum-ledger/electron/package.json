{
  "name": "quantum-ledger",
  "productName": "Quantum Ledger",
  "version": "1.1.0",
  "description": "Track your Star Citizen economy — hauling, mining, trading, refining and crew payouts in one offline desktop app.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ghostncoffee/Quantum-Ledger"
  },
  "author": {
    "name": "ghostncoffee",
    "email": "ghostncoffee@users.noreply.github.com"
  },
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish never",
    "dist:dir": "electron-builder --dir --publish never"
  },
  "dependencies": {
    "@libsql/client": "0.14.0",
    "cors": "2.8.5",
    "express": "4.22.2"
  },
  "devDependencies": {
    "electron": "42.2.0",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "io.quantumledger.app",
    "productName": "Quantum Ledger",
    "copyright": "Copyright © 2025 ghostncoffee",
    "directories": {
      "output": "../release",
      "buildResources": "build-assets"
    },
    "files": [
      "main.js",
      "server-dist/**/*",
      "node_modules/**/*",
      "!node_modules/**/{CHANGELOG.md,README.md,readme.md,changelog.md}",
      "!node_modules/**/test{s,}/**",
      "!node_modules/**/*.map"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "../client/dist",
        "to": "client",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "icon": "build-assets/icon.png",
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Quantum Ledger",
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable-${arch}.${ext}"
    },
    "linux": {
      "icon": "build-assets/icon.png",
      "category": "Finance",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "deb": {
      "depends": ["libgtk-3-0", "libnotify4", "libnss3", "libxss1", "libxtst6", "xdg-utils", "libatspi2.0-0", "libdrm2", "libgbm1", "libxcb-dri3-0"]
    },
    "mac": {
      "icon": "build-assets/icon.png",
      "category": "public.app-category.finance",
      "target": [
        { "target": "dmg",  "arch": ["x64", "arm64"] },
        { "target": "zip",  "arch": ["x64", "arm64"] }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "asar": true
  }
}
