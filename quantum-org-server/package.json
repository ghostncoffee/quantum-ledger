{
  "name": "quantum-org-server",
  "version": "1.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "package:exe": "npm run build && pkg .",
    "list-users": "tsx src/scripts/dev-cli.ts list-users",
    "list-ships": "tsx src/scripts/dev-cli.ts list-ships",
    "list-blueprints": "tsx src/scripts/dev-cli.ts list-blueprints"
  },
  "bin": "dist/index.js",
  "pkg": {
    "targets": [
      "node22-win-x64"
    ],
    "outputPath": "pkg-dist",
    "assets": [
      "public/**/*",
      "node_modules/@libsql/win32-x64-msvc/*.node"
    ]
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "node-cron": "^4.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@yao-pkg/pkg": "^6.20.0",
    "tsx": "^4.15.7",
    "typescript": "^5.9.3"
  }
}
